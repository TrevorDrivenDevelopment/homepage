{
    "name": "homepage-backend",
    "version": "1.0.0",
    "description": "Backend API services for homepage applications",
    "main": "index.js",
    "type": "module",
    "packageManager": "bun@1.2.18",
    "scripts": {
        "build": "bun run build:bundle",
        "build:tsc": "tsc",
        "build:bundle": "node scripts/bundle.mjs",
        "build:bun": "bun build src/index.ts --outdir dist --target node",
        "deploy": "cdk deploy",
        "destroy": "cdk destroy",
        "local": "sam local start-api",
        "dev": "NODE_ENV=development bun --watch src/index.ts",
        "test": "bun test",
        "lint": "eslint src/**/*.ts",
        "type-check": "tsc --noEmit",
        "cdk": "cdk",
        "cdk:diff": "cdk diff",
        "cdk:synth": "cdk synth",
        "cdk:bootstrap": "cdk bootstrap"
    },
    "dependencies": {
        "@aws-sdk/client-ssm": "3.987.0",
        "aws-cdk-lib": "2.238.0",
        "axios": "1.13.5",
        "constructs": "10.4.5",
        "dotenv": "^17.2.4",
        "esbuild": "0.27.3",
        "source-map-support": "0.5.21"
    },
    "devDependencies": {
        "@aws-sdk/types": "3.973.1",
        "@eslint/js": "9.39.2",
        "@types/aws-lambda": "8.10.160",
        "@types/node": "25.2.3",
        "@typescript-eslint/eslint-plugin": "8.55.0",
        "@typescript-eslint/parser": "8.55.0",
        "aws-cdk": "2.1105.0",
        "bun-types": "1.3.9",
        "eslint": "9.39.2",
        "globals": "16.5.0",
        "typescript": "5.9.3"
    }
}
